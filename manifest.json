{
  "manifest_version": 3,
  "name": "Publish to Web",
  "version": "1.0",
  "description": "Scrape tab content, generate website using Gemini API, and publish to Netlify.",
  "permissions": [
    "sidePanel",
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "https://api.netlify.com/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open side panel"
  }
}